# Database
DATABASE_URL=postgresql://user:password@localhost:5432/chatapp

# Server
PORT=3000
NODE_ENV=development

# JWT Secret (ИЗМЕНИТЕ В PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS - Frontend URL
FRONTEND_URL=http://localhost:19006

# Загрузки файлов (кружочки, голос, медиа)
# Локально по умолчанию: папка backend/uploads
# Railway: смонтируйте volume (например на /data) и задайте:
# UPLOADS_DIR=/data/uploads
# PUBLIC_BASE_URL=https://ваш-сервис.up.railway.app
# UPLOADS_DIR=
# PUBLIC_BASE_URL=

# Redis (опционально)
REDIS_URL=redis://localhost:6379

# Email (для отправки кодов подтверждения и восстановления пароля)
# Если не указаны, коды будут выводиться в консоль
# Поддержка: @gmail.com и @yandex.ru/@yandex.com
EMAIL_USER=your-email@yandex.ru
EMAIL_PASSWORD=your-yandex-app-password
